{
  "$description": "Semantic tokens (dark) — overrides only. Same names as light; the build emits these under a .dark selector so mode switching is a class toggle.",
  "background":            { "$type": "color", "$value": "{color.ink.950}" },
  "foreground":            { "$type": "color", "$value": "{color.ink.50}" },
  "card":                  { "$type": "color", "$value": "{color.ink.900}" },
  "card-foreground":       { "$type": "color", "$value": "{color.ink.50}" },
  "popover":               { "$type": "color", "$value": "{color.ink.900}" },
  "popover-foreground":    { "$type": "color", "$value": "{color.ink.50}" },
  "primary":               { "$type": "color", "$value": "{color.olive.500}" },
  "primary-foreground":    { "$type": "color", "$value": "{color.ink.950}" },
  "secondary":             { "$type": "color", "$value": "{color.ink.800}" },
  "secondary-foreground":  { "$type": "color", "$value": "{color.ink.50}" },
  "muted":                 { "$type": "color", "$value": "{color.ink.800}" },
  "muted-foreground":      { "$type": "color", "$value": "{color.ink.400}" },
  "accent":                { "$type": "color", "$value": "{color.ink.800}" },
  "accent-foreground":     { "$type": "color", "$value": "{color.ink.50}" },
  "destructive":           { "$type": "color", "$value": "{color.red.500}" },
  "destructive-foreground":{ "$type": "color", "$value": "{color.ink.50}" },
  "success":               { "$type": "color", "$value": "{color.green.500}" },
  "success-foreground":    { "$type": "color", "$value": "{color.ink.950}" },
  "warning":               { "$type": "color", "$value": "{color.amber.400}" },
  "warning-foreground":    { "$type": "color", "$value": "{color.ink.950}" },
  "border":                { "$type": "color", "$value": "{color.ink.800}" },
  "input":                 { "$type": "color", "$value": "{color.ink.800}" },
  "ring":                  { "$type": "color", "$value": "{color.olive.500}" }
}

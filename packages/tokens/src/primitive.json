{
  "$description": "Primitive tokens — the raw palette. Build-time only; never referenced directly by components. Expressions pick a neutral + accent ramp from here; edit these to retune.",
  "color": {
    "$type": "color",
    "white": { "$value": "oklch(1 0 0)" },
    "black": { "$value": "oklch(0 0 0)" },

    "olive": {
      "$description": "Instrument accent — electric lime-olive. Brighter/higher-chroma so it glows on near-black.",
      "50":  { "$value": "oklch(0.975 0.025 128)" },
      "100": { "$value": "oklch(0.950 0.052 128)" },
      "200": { "$value": "oklch(0.912 0.092 128)" },

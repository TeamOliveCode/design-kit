{
  "$description": "Semantic tokens (light). This is the public API — components reference ONLY these names, never primitives. Names align with the shadcn convention so any shadcn-compatible component just works.",
  "background":            { "$type": "color", "$value": "{color.ink.50}" },
  "foreground":            { "$type": "color", "$value": "{color.ink.950}" },
  "card":                  { "$type": "color", "$value": "{color.white}" },
  "card-foreground":       { "$type": "color", "$value": "{color.ink.950}" },
  "popover":               { "$type": "color", "$value": "{color.white}" },
  "popover-foreground":    { "$type": "color", "$value": "{color.ink.950}" },
  "primary":               { "$type": "color", "$value": "{color.olive.700}" },
  "primary-foreground":    { "$type": "color", "$value": "{color.ink.50}" },
  "secondary":             { "$type": "color", "$value": "{color.ink.100}" },
  "secondary-foreground":  { "$type": "color", "$value": "{color.ink.900}" },
  "muted":                 { "$type": "color", "$value": "{color.ink.100}" },
  "muted-foreground":      { "$type": "color", "$value": "{color.ink.500}" },
  "accent":                { "$type": "color", "$value": "{color.ink.100}" },
  "accent-foreground":     { "$type": "color", "$value": "{color.ink.900}" },
  "destructive":           { "$type": "color", "$value": "{color.red.600}" },
  "destructive-foreground":{ "$type": "color", "$value": "{color.ink.50}" },
  "success":               { "$type": "color", "$value": "{color.green.500}" },
  "success-foreground":    { "$type": "color", "$value": "{color.ink.50}" },
  "warning":               { "$type": "color", "$value": "{color.amber.500}" },
  "warning-foreground":    { "$type": "color", "$value": "{color.ink.950}" },
  "border":                { "$type": "color", "$value": "{color.ink.200}" },
  "input":                 { "$type": "color", "$value": "{color.ink.200}" },
  "ring":                  { "$type": "color", "$value": "{color.olive.700}" },
  "radius":                { "$type": "dimension", "$value": "0.5rem" }
}
